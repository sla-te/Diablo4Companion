# Line-ending policy
# ------------------
# Store and check out LF everywhere. Modern Windows (Visual Studio, VS Code,
# .NET, Git, PowerShell) handles LF fine, so there is no reason to keep CRLF.
# `text=auto` lets Git auto-detect text vs binary; `eol=lf` forces LF on
# checkout regardless of the local core.autocrlf setting.
* text=auto eol=lf

# Binary assets: never diff, merge, or touch line endings
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.bmp         binary
*.xcf         binary
*.zip         binary
*.7z          binary
*.dll         binary
*.exe         binary
*.pdb         binary
*.traineddata binary
*.gst         binary

# Nice-to-have: language-aware diff for C#
*.cs          diff=csharp

# GitHub Linguist: keep generated/vendored data out of language stats and diffs
*.Designer.cs              linguist-generated=true
D4Companion/Data/**        linguist-generated=true
downloads/systempresets/** linguist-vendored=true
